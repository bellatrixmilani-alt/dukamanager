const CounterTab = ({ inventory, txs, cart, setCart, initiateSale, modal, t, theme }) => {
  const [search, setSearch] = useState('');
  const [orderMode, setOrderMode] = useState(false); // manual text entry mode
  const [manualItemName, setManualItemName] = useState('');
  const [manualItemQty, setManualItemQty]   = useState(1);
  const [manualItemPrice, setManualItemPrice]= useState('');
  const [suggestions, setSuggestions]       = useState([]);

  const cashCount  = txs.filter(tx=>tx.type==='CASH').length;
  const mpesaCount = txs.filter(tx=>tx.type==='MPESA').length;
  const deniCount  = txs.filter(tx=>tx.type==='DENI').length;
  const total      = cashCount+mpesaCount+deniCount;

  const addToCart = (p) => {
    const ex = cart.find(i=>i.id===p.id);
    setCart(ex?cart.map(i=>i.id===p.id?{...i,qty:i.qty+1}:i):[...cart,{...p,qty:1,price:p.sellPrice,manual:false}]);
  };

  const removeFromCart  = id => setCart(cart.filter(i=>i.id!==id));
  const updateQty       = (id,qty) => { if(qty<1) return removeFromCart(id); setCart(cart.map(i=>i.id===id?{...i,qty}:i)); };
  const cartTotal       = Math.round(cart.reduce((a,i)=>a+i.price*i.qty,0));
  const cartProfit      = Math.round(cart.reduce((a,i)=>a+((i.buyPrice||0)*i.qty?((i.price-(i.buyPrice||0))*i.qty):0),0));

  const handleManualSearch = (val) => {
    setManualItemName(val);
    if(val.length>1) setSuggestions(inventory.filter(i=>i.name.toLowerCase().includes(val.toLowerCase())).slice(0,5));
    else setSuggestions([]);
  };
  const addManualItem = (item=null) => {
    if(item) {
      addToCart(item); setManualItemName(''); setManualItemQty(1); setManualItemPrice(''); setSuggestions([]);
    } else if(manualItemName.trim()) {
      const found = inventory.find(i=>i.name.toLowerCase()===manualItemName.toLowerCase());
      if(found) { addToCart(found); }
      else { setCart(c=>[...c,{id:`m_${Date.now()}`,name:manualItemName.trim(),qty:manualItemQty,price:Number(manualItemPrice)||0,buyPrice:0,manual:true}]); }
      setManualItemName(''); setManualItemQty(1); setManualItemPrice(''); setSuggestions([]);
