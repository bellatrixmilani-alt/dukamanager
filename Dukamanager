const ExpTagBadge = ({ type, t }) => {
  const cfg = {
    fixed:     { label:t('mustPay'),   cls:'bg-red-100 text-red-700 border-red-200',    icon:<Lock size={8}/> },
    recurring: { label:t('recurring'), cls:'bg-amber-100 text-amber-700 border-amber-200', icon:<Repeat size={8}/> },
    oneoff:    { label:t('oneOff'),    cls:'bg-slate-100 text-slate-600 border-slate-200', icon:<Tag size={8}/> },
  };
  const c = cfg[type]||cfg.oneoff;
  return <span className={`inline-flex items-center gap-1 text-[7px] font-black px-1.5 py-0.5 rounded-full border ${c.cls}`}>{c.icon}{c.label}</span>;
};

const ExpenseAnalysis = ({ expenses, t, onDelete, theme }) => {
  const [period, setPeriod] = useState('monthly');
  const [activeType, setActiveType] = useState('all');
  const REF_DATE = new Date('2024-03-27');

  const filtered = useMemo(()=>{
    let list = expenses;
    if(period==='weekly'){const cut=new Date(REF_DATE);cut.setDate(REF_DATE.getDate()-7);list=list.filter(e=>new Date(e.date)>=cut);}
    else if(period==='monthly'){const cut=new Date(REF_DATE);cut.setDate(REF_DATE.getDate()-30);list=list.filter(e=>new Date(e.date)>=cut);}
    if(activeType!=='all') list=list.filter(e=>e.type===activeType);
    return list;
  },[expenses,period,activeType]);

  const allPeriod = useMemo(()=>{
    let list = expenses;
    if(period==='weekly'){const cut=new Date(REF_DATE);cut.setDate(REF_DATE.getDate()-7);list=list.filter(e=>new Date(e.date)>=cut);}
    else if(period==='monthly'){const cut=new Date(REF_DATE);cut.setDate(REF_DATE.getDate()-30);list=list.filter(e=>new Date(e.date)>=cut);}
    return list;
  },[expenses,period]);

  const totals = {
    all:       allPeriod.reduce((a,e)=>a+e.amount,0),
    fixed:     allPeriod.filter(e=>e.type==='fixed').reduce((a,e)=>a+e.amount,0),
    recurring: allPeriod.filter(e=>e.type==='recurring').reduce((a,e)=>a+e.amount,0),
    oneoff:    allPeriod.filter(e=>e.type==='oneoff').reduce((a,e)=>a+e.amount,0),
  };

  const sections = [
    {key:'all',label:'All',total:totals.all,count:allPeriod.length,cls:'border-slate-300'},
    {key:'fixed',label:t('mustPay'),total:totals.fixed,count:allPeriod.filter(e=>e.type==='fixed').length,cls:'border-red-400'},
    {key:'recurring',label:t('recurring'),total:totals.recurring,count:allPeriod.filter(e=>e.type==='recurring').length,cls:'border-amber-400'},
    {key:'oneoff',label:t('oneOff'),total:totals.oneoff,count:allPeriod.filter(e=>e.type==='oneoff').length,cls:'border-slate-300'},
  ];
  const typeLeft = {fixed:'border-l-red-400 bg-red-50/20',recurring:'border-l-amber-400 bg-amber-50/20',oneoff:'border-l-slate-300 bg-white'};

  return (
    <div className="flex flex-col gap-4">
      <div className="flex items-center gap-2 flex-wrap">
        <span className="text-[9px] font-black uppercase text-slate-400 tracking-wider">{t('expPeriod')}:</span>
        {[['weekly',t('weekly')],['monthly',t('monthly')],['all',t('allTime')]].map(([k,l])=>(
          <button key={k} onClick={()=>setPeriod(k)}
            className={`px-4 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all ${period===k?'text-white shadow-md':'bg-white border border-slate-200 text-slate-500 hover:border-slate-300'}`}
            style={period===k?{background:theme.primary}:{}}>
            {l}
          </button>
        ))}
      </div>

      <div className="grid grid-cols-2 sm:grid-cols-4 gap-2.5">
        {sections.map(s=>(
          <button key={s.key} onClick={()=>setActiveType(s.key)}
            className={`p-3 rounded-2xl border-2 text-left transition-all ${activeType===s.key?'border-slate-800 shadow-md bg-white':'border-slate-200 bg-white hover:border-slate-300'}`}>
            <div className="flex items-center justify-between mb-1">
              <p className="text-[8px] font-black uppercase text-slate-400">{s.label}</p>
              {s.key!=='all'&&<ExpTagBadge type={s.key} t={t}/>}
            </div>
            <p className="text-base font-black text-slate-800">KSh {s.total.toLocaleString()}</p>
            <p className="text-[8px] text-slate-400 font-bold">{s.count} items</p>
          </button>
        ))}
      </div>

      <div className="flex flex-wrap gap-3 p-3 bg-slate-50 rounded-2xl border border-slate-200 text-[9px]">
        <div className="flex items-center gap-2"><span className="px-2 py-0.5 bg-red-50 text-red-600 border border-red-200 rounded-full font-black">🔴 {t('mustPay')}</span><span className="text-slate-500">Rent, Staff, Electricity — non-negotiable monthly costs</span></div>
        <div className="flex items-center gap-2"><span className="px-2 py-0.5 bg-amber-50 text-amber-600 border border-amber-200 rounded-full font-black">🟡 {t('recurring')}</span><span className="text-slate-500">Transport, Packaging — repeats but varies</span></div>
        <div className="flex items-center gap-2"><span className="px-2 py-0.5 bg-slate-100 text-slate-600 border border-slate-200 rounded-full font-black">⚪ {t('oneOff')}</span><span className="text-slate-500">Repairs, Emergency — unexpected costs</span></div>
      </div>

      <div className="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm">
        <div className="p-4 border-b border-slate-100 bg-slate-50/50 flex items-center gap-2">
          <Receipt size={12} className="text-slate-500"/>
          <h3 className="text-[9px] font-black uppercase tracking-widest text-slate-500">{t('allExpenses')} ({filtered.length})</h3>
        </div>
        <div className="divide-y divide-slate-100">
          {filtered.length===0&&<div className="p-10 text-center text-slate-400"><Receipt size={24} className="mx-auto mb-2 opacity-30"/><p className="text-xs font-bold">No expenses in this period</p></div>}
          {filtered.map(exp=>(
            <div key={exp.id} className={`flex items-center gap-3 p-4 hover:bg-slate-50 transition-colors border-l-4 ${typeLeft[exp.type]||'bg-white'}`}>
              <div className={`w-9 h-9 rounded-xl flex items-center justify-center shrink-0 ${exp.type==='fixed'?'bg-red-50':exp.type==='recurring'?'bg-amber-50':'bg-slate-100'}`}>
                {exp.type==='fixed'?<Lock size={13} className="text-red-500"/>:exp.type==='recurring'?<Repeat size={13} className="text-amber-500"/>:<Tag size={13} className="text-slate-400"/>}
              </div>
              <div className="flex-1 min-w-0">
                <div className="flex items-center gap-2 flex-wrap"><p className="font-black text-sm text-slate-800">{exp.category}</p><ExpTagBadge type={exp.type} t={t}/></div>
                <p className="text-[9px] text-slate-500 font-bold truncate">{exp.note} · {exp.date}</p>
              </div>
              <div className="flex items-center gap-2 shrink-0">
                <p className="font-black text-slate-800 whitespace-nowrap">KSh {exp.amount.toLocaleString()}</p>
                <button onClick={()=>onDelete(exp.id)} className="text-slate-300 hover:text-red-500 p-1.5 rounded hover:bg-red-50 transition-colors"><Trash2 size={12}/></button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
};

