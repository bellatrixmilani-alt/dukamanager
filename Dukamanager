const useOffline = () => {
  const open = () => new Promise((res,rej) => {
    const r = indexedDB.open('DukaDB_v6',1);
    r.onupgradeneeded = e => { if(!e.target.result.objectStoreNames.contains('kv')) e.target.result.createObjectStore('kv'); };
    r.onsuccess = e => res(e.target.result);
    r.onerror = () => rej(r.error);
  });
  const save = async (key,val) => { try { const db=await open(); db.transaction('kv','readwrite').objectStore('kv').put(JSON.stringify(val),key); } catch(_){} };
  const load = async (key) => { try { const db=await open(); return new Promise(res=>{ const r=db.transaction('kv','readonly').objectStore('kv').get(key); r.onsuccess=()=>res(r.result?JSON.parse(r.result):null); r.onerror=()=>res(null); }); } catch(_){return null;} };
  return { save, load };
};

