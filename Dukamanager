          <form onSubmit={onAddExpense} className="space-y-3">
            <div>
              <label className="text-[9px] font-black uppercase text-slate-500 tracking-wider block mb-1">Category</label>
              <select name="category" className="w-full bg-slate-50 rounded-xl p-3 font-bold text-sm outline-none border border-slate-200 text-slate-700" required>
                <optgroup label="🔴 Must Pay (Fixed)">{FIXED_CATS.map(c=><option key={c} value={c}>{c}</option>)}</optgroup>
                <optgroup label="🟡 Recurring">{['Transport','Packaging','Internet','Insurance'].map(c=><option key={c} value={c}>{c}</option>)}</optgroup>
                <optgroup label="⚪ One-Off">{['Repairs','Other','Emergency'].map(c=><option key={c} value={c}>{c}</option>)}</optgroup>
              </select>
            </div>
            <div className="grid grid-cols-2 gap-3">
              <div><label className="text-[9px] font-black uppercase text-slate-500 tracking-wider block mb-1">{t('amount')}</label><input name="amount" type="number" min="1" placeholder="e.g. 1200" required className="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 font-bold text-sm outline-none focus:border-blue-500 placeholder:text-slate-400"/></div>
              <div><label className="text-[9px] font-black uppercase text-slate-500 tracking-wider block mb-1">{t('date')}</label><input name="date" type="date" required className="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 font-bold text-sm outline-none focus:border-blue-500"/></div>
            </div>
            <div><label className="text-[9px] font-black uppercase text-slate-500 tracking-wider block mb-1">{t('note')}</label><input name="note" placeholder="e.g. KPLC token" className="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 font-bold text-sm outline-none focus:border-blue-500 placeholder:text-slate-400"/></div>
            <button type="submit" className="w-full py-3.5 text-white rounded-xl font-black text-xs uppercase shadow-md mt-1" style={{background:theme.primary}}>{t('recordExpBtn')}</button>
          </form>
        </Modal>
      )}
      {modals.restock&&(
        <Modal title={t('restockOrder')} onClose={()=>{modal('restock',false);setRestockTarget(null);}}>
          <form onSubmit={onCreateRestock} className="space-y-3">
            {restockTarget?<div className="bg-slate-50 border border-slate-100 rounded-xl p-3"><p className="text-[9px] text-slate-400 uppercase font-black">Item</p><p className="font-black text-sm text-slate-800">{restockTarget.name}</p><p className="text-[9px] font-bold" style={{color:theme.primary}}>Buy price: KSh {restockTarget.buyPrice}</p></div>:<select name="itemName" className="w-full bg-slate-50 rounded-xl p-3 font-bold text-sm outline-none border border-slate-200 text-slate-700">{inventory.map(i=><option key={i.id} value={i.name}>{i.name}</option>)}</select>}
            <select name="supplier" className="w-full bg-slate-50 rounded-xl p-3 font-bold text-sm outline-none border border-slate-200 text-slate-700">{suppliers.map(s=><option key={s.id} value={s.id}>{s.name}</option>)}</select>
            <MI name="qty" type="number" placeholder={t('qtyToOrder')} required/>
            <button type="submit" className="w-full py-3.5 text-white rounded-xl font-black text-xs uppercase shadow-md mt-1" style={{background:theme.primary}}>{t('placeOrder')}</button>
          </form>
        </Modal>
      )}
    </div>
  );
}
