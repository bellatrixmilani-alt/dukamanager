const PinLock = ({ shopName, pin, onUnlock, lang, theme }) => {
  const t = k => LANG[lang][k]||k;
  const [entry,setEntry] = useState('');
  const [err,setErr]     = useState('');
  const [showReset,setShowReset] = useState(false);
  const handleKey = k => {
    if(k==='del'){setEntry(e=>e.slice(0,-1));return;}
    if(entry.length>=4)return;
    const next=entry+k;
    setEntry(next);
    if(next.length===4){if(next===pin){onUnlock();}else{setErr(t('wrongPin'));setTimeout(()=>{setEntry('');setErr('');},900);}}
  };
  return (
    <div className="min-h-screen bg-slate-900 flex items-center justify-center p-4">
      <div className="w-full max-w-xs text-center">
        <div className="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4" style={{background:theme.primary}}><Lock size={28} className="text-white"/></div>
