const PerformanceReport = ({ inventory, t, theme }) => {
  const [perfFilter, setPerfFilter] = useState('month');
  const sorted = useMemo(()=>[...inventory].sort((a,b)=>b.salesCount[perfFilter]-a.salesCount[perfFilter]),[inventory,perfFilter]);
  const labelMap = { week:t('thisWeek'), month:t('thisMonth'), year:t('thisYear') };
  const periodDesc = { week:'Sales counted over the last 7 days', month:'Sales counted over the last 30 days', year:'Sales counted over the last 365 days' };
  return (
    <div className="flex flex-col gap-5">
      <div className="flex flex-col sm:flex-row sm:items-center gap-3">
        <div className="flex bg-white p-1.5 rounded-2xl border border-slate-200 gap-1 shadow-sm">
          {['week','month','year'].map(f=>(
            <button key={f} onClick={()=>setPerfFilter(f)}
              className={`px-4 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all ${perfFilter===f?'text-white shadow-md':'text-slate-500 hover:bg-slate-100'}`}
              style={perfFilter===f?{background:theme.primary}:{}}>
              {labelMap[f]}
            </button>
          ))}
        </div>
        <div className="flex items-center gap-1.5 text-[9px] text-slate-500 font-bold bg-blue-50 border border-blue-100 rounded-xl px-3 py-2">
          <Info size={11} className="text-blue-500 shrink-0"/>{periodDesc[perfFilter]}
        </div>
      </div>
      <div className="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div className="bg-white border border-slate-200 p-5 rounded-3xl space-y-4 shadow-sm">
          <div className="flex justify-between items-center">
            <h3 className="font-black text-[9px] uppercase tracking-widest text-emerald-600">{t('topMoving')}</h3>
            <BarChart3 size={14} className="text-emerald-500"/>
          </div>
          <div className="space-y-2">
            {sorted.slice(0,5).map((p,i)=>{
              const maxSales = sorted[0]?.salesCount[perfFilter]||1;
              return (
                <div key={p.id} className="space-y-1">
                  <div className="flex justify-between items-center">
                    <span className="text-sm font-bold text-slate-800">#{i+1} {p.name}</span>
                    <span className="text-[9px] font-black px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-700">{p.salesCount[perfFilter]} sold</span>
                  </div>
                  <div className="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                    <div className="h-full rounded-full bg-emerald-400 transition-all duration-500" style={{width:`${(p.salesCount[perfFilter]/maxSales)*100}%`}}/>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
        <div className="bg-white border border-slate-200 p-5 rounded-3xl space-y-4 shadow-sm">
          <div className="flex justify-between items-center">
            <h3 className="font-black text-[9px] uppercase tracking-widest text-amber-600">{t('slowMoving')}</h3>
            <TrendingDown size={14} className="text-amber-500"/>
          </div>
          <div className="space-y-2">
            {sorted.slice(-5).reverse().map(p=>(
              <div key={p.id} className="flex justify-between items-center p-3 bg-amber-50/50 rounded-2xl border border-amber-100">
                <span className="text-sm font-bold text-slate-600">{p.name}</span>
                <div className="text-right">
                  <p className="text-[9px] font-black text-amber-700 bg-amber-100 px-2 py-0.5 rounded-full">{p.salesCount[perfFilter]} sold</p>
                  <p className="text-[8px] text-slate-400 mt-0.5">in {labelMap[perfFilter].toLowerCase()}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  );
};

// ─────────────────────────────────────────
//  MAIN APP
// ─────────────────────────────────────────
export default function App() {
  const { save, load } = useOffline();
  const [isOnboarded, setIsOnboarded] = useState(false);
  const [shopInfo,    setShopInfo]    = useState(null);
  const [isPinLocked, setIsPinLocked] = useState(true);
  const [lang,        setLang]        = useState('en');
  const [themeKey,    setThemeKeyState]= useState('blue');
  const theme = THEMES[themeKey];
  const t = useCallback(k=>LANG[lang]?.[k]||k,[lang]);
  const [isOnline, setIsOnline] = useState(navigator.onLine);
  useEffect(()=>{
    const on=()=>setIsOnline(true),off=()=>setIsOnline(false);
    window.addEventListener('online',on);window.addEventListener('offline',off);
    return()=>{window.removeEventListener('online',on);window.removeEventListener('offline',off);};
  },[]);

  const setThemeKey = (k) => { setThemeKeyState(k); save('themeKey',k); };

  const [tab,          setTab]          = useState('sales');
  const [stockTab,     setStockTab]     = useState('inventory');
  const [reportTab,    setReportTab]    = useState('today');
  const [month,        setMonth]        = useState('March');
  const [search,       setSearch]       = useState('');
  const [mobileNavOpen,setMobileNavOpen]= useState(false);
  const [notification, setNotification] = useState(null);
  const [modals,       setModals]       = useState({ addProduct:false, addCustomer:false, customerPick:false, addSupplier:false, addExpense:false, restock:false });
  const [restockTarget,    setRestockTarget]    = useState(null);
  const [pendingPayment,   setPendingPayment]   = useState(null);
  const [showConfirm,      setShowConfirm]      = useState(false);
  const [showMpesaPhone,   setShowMpesaPhone]   = useState(false);
  const [recurringPhone,   setRecurringPhone]   = useState(null);
  const [discount5,        setDiscount5]        = useState(false);
  const [deleteConfirmSup, setDeleteConfirmSup] = useState(null);
  const [newSupRating,     setNewSupRating]     = useState(4);
  const [newSupItems,      setNewSupItems]      = useState([]);
  const [newSupItemInput,  setNewSupItemInput]  = useState('');
  const [clearDebtTarget,  setClearDebtTarget]  = useState(null); // {customer, debt}
  const [dismissedNotifs,  setDismissedNotifs]  = useState([]);

  const [inventory, setInventory] = useState(SEED_INVENTORY);
  const [deni,      setDeni]      = useState(SEED_DENI);
  const [suppliers, setSuppliers] = useState(SEED_SUPPLIERS);
  const [restocks,  setRestocks]  = useState(SEED_RESTOCKS);
  const [expenses,  setExpenses]  = useState(SEED_EXPENSES);
  const [txs,       setTxs]       = useState(SEED_TX);
  const [cart,      setCart]      = useState([]);
  const [mpesaLog,  setMpesaLog]  = useState([]);

  useEffect(()=>{
    (async()=>{
      const [inv,dn,sup,rst,exp,tx,shop,mlog,tk,dn2] = await Promise.all([
        load('inventory'),load('deni'),load('suppliers'),load('restocks'),
        load('expenses'),load('txs'),load('shopInfo'),load('mpesaLog'),load('themeKey'),load('dismissedNotifs')
      ]);
      if(inv)setInventory(inv);if(dn)setDeni(dn);if(sup)setSuppliers(sup);
      if(rst)setRestocks(rst);if(exp)setExpenses(exp);if(tx)setTxs(tx);
      if(mlog)setMpesaLog(mlog);if(tk)setThemeKeyState(tk);if(dn2)setDismissedNotifs(dn2);
      if(shop){setShopInfo(shop);setLang(shop.lang||'en');setIsOnboarded(true);}
    })();
  },[]);

  useEffect(()=>{save('inventory',inventory);},[inventory]);
  useEffect(()=>{save('deni',deni);},[deni]);
  useEffect(()=>{save('suppliers',suppliers);},[suppliers]);
  useEffect(()=>{save('restocks',restocks);},[restocks]);
  useEffect(()=>{save('expenses',expenses);},[expenses]);
  useEffect(()=>{save('txs',txs);},[txs]);
  useEffect(()=>{save('mpesaLog',mpesaLog);},[mpesaLog]);
  useEffect(()=>{save('dismissedNotifs',dismissedNotifs);},[dismissedNotifs]);

  const notifications = useMemo(()=>buildNotifications(inventory,deni,txs,expenses).filter(n=>!dismissedNotifs.includes(n.id)),[inventory,deni,txs,expenses,dismissedNotifs]);
  const dismissNotif  = id => setDismissedNotifs(prev=>[...prev,id]);

  const effectiveCartSale = useMemo(()=>cart.reduce((a,i)=>a+i.price*i.qty,0)*(discount5?0.95:1),[cart,discount5]);
  const cartProfit        = useMemo(()=>cart.reduce((a,i)=>a+((i.price-(i.buyPrice||0))*i.qty),0)*(discount5?0.95:1),[cart,discount5]);
  const stockValue        = useMemo(()=>inventory.reduce((a,i)=>a+i.buyPrice*i.stock,0),[inventory]);
  const totalDeni         = useMemo(()=>deni.reduce((a,c)=>a+balance(c.debts),0),[deni]);
  const totalExpenses     = useMemo(()=>expenses.reduce((a,e)=>a+e.amount,0),[expenses]);
  const lowStockItems     = useMemo(()=>inventory.filter(i=>i.stock<10),[inventory]);

  const loanScore = useMemo(()=>{
    const mths=Object.values(HISTORY);const profits=mths.map(m=>m.profit);
    const pg=(profits[2]-profits[0])/profits[0];
    const s1=Math.min(30,Math.round(pg*100));
    const s2=Math.max(0,Math.round((1-totalDeni/mths[2].sales)*25));
    const s3=Math.max(0,Math.round((1-totalExpenses/mths[2].sales)*20));
    const s4=Math.min(15,Math.round(((mths[2].sales-mths[0].sales)/mths[0].sales)*50));
    const s5=Math.max(0,10-lowStockItems.length*2);
    return {total:Math.min(100,s1+s2+s3+s4+s5),breakdown:[
      {label:'Profit Consistency',score:s1,max:30},{label:'Debt Management',score:s2,max:25},
      {label:'Expense Control',score:s3,max:20},{label:'Sales Growth',score:s4,max:15},{label:'Stock Health',score:s5,max:10},
    ]};
  },[totalDeni,totalExpenses,lowStockItems]);

  const toast   = msg => { setNotification(msg); setTimeout(()=>setNotification(null),3000); };
  const modal   = (key,val=true) => setModals(m=>({...m,[key]:val}));
  const today   = () => todayStr();
  const isRecur = phone => phone&&mpesaLog.filter(e=>e.phone===phone).length>=3;

  const initiateSale = (method, customerId=null) => {
    if(!cart.length)return;
    setPendingPayment({method,customerId}); setDiscount5(false); setShowConfirm(true);
  };
  const handleConfirmSale = () => {
    setShowConfirm(false);
    if(pendingPayment.method==='MPESA') setShowMpesaPhone(true);
    else finalizeSale(pendingPayment.method,pendingPayment.customerId,null);
  };
  const handleMpesaPhone = phone => {
    setShowMpesaPhone(false);
    if(phone&&isRecur(phone)) setRecurringPhone(phone);
    else finalizeSale('MPESA',null,phone);
  };
  const handleRecurring = apply => { setDiscount5(apply); setRecurringPhone(null); finalizeSale('MPESA',null,recurringPhone,apply); };
  const finalizeSale = (method,customerId,mpesaPhone,discountApplied=discount5) => {
    const fa = Math.round(cart.reduce((a,i)=>a+i.price*i.qty,0)*(discountApplied?0.95:1));
    const fp = Math.round(cart.reduce((a,i)=>a+(i.price-(i.buyPrice||0))*i.qty,0)*(discountApplied?0.95:1));
    setTxs(prev=>[{id:Date.now(),type:method,amount:fa,profit:fp,time:timeNow(),date:today(),items:cart.length},...prev]);
    setInventory(prev=>prev.map(item=>{
      const ci=cart.find(c=>c.id===item.id);
      return ci&&!ci.manual?{...item,stock:item.stock-ci.qty,salesCount:{week:item.salesCount.week+ci.qty,month:item.salesCount.month+ci.qty,year:item.salesCount.year+ci.qty}}:item;
    }));
    if(method==='DENI'&&customerId) {
      setDeni(prev=>prev.map(c=>c.id===customerId?{...c,debts:[...c.debts,{id:Date.now(),amount:fa,date:today(),note:cart.map(i=>i.name).join(', ')}]}:c));
      toast(`✓ Deni recorded`);
    } else {
      if(mpesaPhone) setMpesaLog(prev=>[...prev,{phone:mpesaPhone,date:today()}]);
      toast(`✓ ${method} Sale${discountApplied?' (5% off!) 🌟':''}`);
    }
    setCart([]);modal('customerPick',false);setPendingPayment(null);setDiscount5(false);
  };

  const handleClearDebt = (method) => {
    if(!clearDebtTarget)return;
    const {customer,debt} = clearDebtTarget;
    setDeni(prev=>prev.map(c=>c.id!==customer.id?c:{...c,debts:c.debts.filter(d=>d.id!==debt.id)}));
    setTxs(prev=>[{id:Date.now(),type:method,amount:debt.amount,time:timeNow(),date:today(),items:1,note:`Debt cleared: ${customer.name}`},...prev]);
    toast(`✓ KSh ${debt.amount.toLocaleString()} cleared (${method}) — ${customer.name}`);
    setClearDebtTarget(null);
  };

  const smsCustomer   = c => { const bal=balance(c.debts); const msg=`Habari ${c.name.split(' ')[0]}, balance yako ni KSh ${bal.toLocaleString()}. Karibu kulipa. Asante! 🙏`; window.open(`sms:${c.phone}?body=${encodeURIComponent(msg)}`); };
  const callSupplier  = s => { window.open(`tel:${s.phone}`); toast(`Calling ${s.name}...`); };
  const deleteSupplier= id => { setSuppliers(prev=>prev.filter(s=>s.id!==id)); setDeleteConfirmSup(null); toast('Supplier removed.'); };
  const markDelivered = id => setRestocks(prev=>prev.map(r=>r.id===id?{...r,status:'delivered'}:r));

  const generateEODReport = () => {
    const totSales=txs.reduce((a,b)=>a+b.amount,0);
    const cash=txs.filter(t=>t.type==='CASH').reduce((a,b)=>a+b.amount,0);
    const mpesa=txs.filter(t=>t.type==='MPESA').reduce((a,b)=>a+b.amount,0);
    const deniT=txs.filter(t=>t.type==='DENI').reduce((a,b)=>a+b.amount,0);
    const low=lowStockItems.map(i=>`• ${i.name}: ${i.stock} left`).join('\n');
    const rpt=`🏪 *DUKA END-OF-DAY REPORT*\n📅 ${new Date().toLocaleDateString('en-KE',{weekday:'long',day:'numeric',month:'long',year:'numeric'})}\n━━━━━━━━━━━━━━━\n💰 *SALES*\nTotal: KSh ${totSales.toLocaleString()}\n├ Cash:  KSh ${cash.toLocaleString()}\n├ MPesa: KSh ${mpesa.toLocaleString()}\n└ Deni:  KSh ${deniT.toLocaleString()}\n\n📦 *LOW STOCK*\n${low||'✅ All well stocked'}\n\n💸 *EXPENSES* KSh ${totalExpenses.toLocaleString()}\n📊 *DENI OUT* KSh ${totalDeni.toLocaleString()}\n🏦 *LOAN SCORE* ${loanScore.total}/100\n─────────────────────\nReport by Duka Yangu ✅`;
    window.open(`https://wa.me/?text=${encodeURIComponent(rpt)}`);
    toast('EOD Report shared!');
  };

  const onAddProduct  = e => { e.preventDefault(); const f=new FormData(e.target); setInventory(prev=>[...prev,{id:Date.now(),name:f.get('name'),buyPrice:+f.get('buy'),sellPrice:+f.get('sell'),stock:+f.get('stock'),unit:f.get('unit'),salesCount:{week:0,month:0,year:0}}]); modal('addProduct',false); toast(`"${f.get('name')}" added`); };
  const onAddCustomer = e => { e.preventDefault(); const f=new FormData(e.target); setDeni(prev=>[...prev,{id:Date.now(),name:f.get('name'),phone:f.get('phone'),debts:[]}]); modal('addCustomer',false); toast(`${f.get('name')} registered!`); };
  const onAddSupplier = e => { e.preventDefault(); const f=new FormData(e.target); setSuppliers(prev=>[...prev,{id:Date.now(),name:f.get('name'),phone:f.get('phone'),contact:f.get('contact'),items:newSupItems,lastOrder:today(),rating:newSupRating}]); modal('addSupplier',false); setNewSupRating(4);setNewSupItems([]);setNewSupItemInput(''); toast('Supplier added!'); };

  // ← FIXED: expense form now correctly adds to state
  const onAddExpense = e => {
    e.preventDefault();
    const f = new FormData(e.target);
    const cat = f.get('category');
    const newExp = {
      id: Date.now(),
      category: cat,
      type: getExpType(cat),
      amount: Number(f.get('amount')),
      date: f.get('date') || today(),
      note: f.get('note') || '',
    };
    setExpenses(prev => [newExp, ...prev]);
    e.target.reset();
    modal('addExpense', false);
    toast(`Expense recorded: KSh ${newExp.amount.toLocaleString()}`);
  };

  const onCreateRestock = e => { e.preventDefault(); const f=new FormData(e.target); const qty=+f.get('qty'); setRestocks(prev=>[...prev,{id:Date.now(),supplierId:+f.get('supplier'),item:restockTarget?.name||f.get('itemName'),qty,totalCost:qty*(restockTarget?.buyPrice||0),status:'pending',date:today()}]); modal('restock',false); setRestockTarget(null); toast('Restock order placed!'); };
  const handleOnboardingComplete = async info => { setShopInfo(info);setLang(info.lang);setIsOnboarded(true);setIsPinLocked(false);await save('shopInfo',info); };

  if(!isOnboarded)return <OnboardingScreen onComplete={handleOnboardingComplete}/>;
  if(isPinLocked&&shopInfo?.pin)return <PinLock shopName={shopInfo?.shopName} pin={shopInfo?.pin} lang={lang} onUnlock={()=>setIsPinLocked(false)} theme={theme}/>;

  const tabLabels = { sales:t('counter'), stock:t('warehouse'), deni:t('creditBook'), expenses:t('expenses'), trends:t('reports'), notifications:t('notifications'), settings:'Brand' };

  return (
    <div className="flex h-screen bg-slate-100 text-slate-900 font-sans overflow-hidden">
      {/* Toast */}
      {notification&&(
        <div className="fixed top-4 left-1/2 -translate-x-1/2 z-[300] bg-slate-900 text-white px-5 py-2.5 rounded-2xl shadow-2xl flex items-center gap-2">
          <CheckCircle2 size={14} style={{color:theme.accent}}/><span className="font-bold text-xs">{notification}</span>
        </div>
      )}

      {/* Confirm sale */}
      {showConfirm&&pendingPayment&&(
        <SaleConfirmModal
          amount={Math.round(effectiveCartSale)} profit={Math.round(cartProfit)}
          orderItems={cart.map(i=>({name:i.name,qty:i.qty,price:i.price}))}
          method={pendingPayment.method} discount5={discount5} t={t} theme={theme}
          onConfirm={handleConfirmSale} onCancel={()=>{setShowConfirm(false);setPendingPayment(null);}}/>
      )}
      {showMpesaPhone&&<MpesaPhoneModal onSubmit={handleMpesaPhone} onSkip={()=>{setShowMpesaPhone(false);finalizeSale('MPESA',null,null);}} t={t}/>}
      {recurringPhone&&<RecurringModal phone={recurringPhone} onApply={()=>handleRecurring(true)} onSkip={()=>handleRecurring(false)} t={t}/>}
      {clearDebtTarget&&<ClearDebtModal debt={clearDebtTarget.debt} customer={clearDebtTarget.customer} onClear={handleClearDebt} onCancel={()=>setClearDebtTarget(null)} t={t} theme={theme}/>}

      {/* Sidebar */}
      <Sidebar tab={tab} setTab={setTab} t={t} shopInfo={shopInfo} lang={lang} setLang={setLang} save={save} setShopInfo={setShopInfo} isOnline={isOnline} stockValue={stockValue} mobileOpen={mobileNavOpen} setMobileOpen={setMobileNavOpen} theme={theme} notifCount={notifications.length}/>

      {/* Main */}
      <div className="flex-1 flex flex-col min-w-0 overflow-hidden">
        <header className="bg-white border-b border-slate-200 px-4 py-3 flex items-center gap-3 flex-shrink-0">
          <button onClick={()=>setMobileNavOpen(true)} className="lg:hidden p-2 rounded-xl hover:bg-slate-100 text-slate-500"><Menu size={18}/></button>
          <h1 className="font-black text-sm text-slate-800 uppercase tracking-wide">{tabLabels[tab]}</h1>
          {notifications.length>0&&tab!=='notifications'&&(
            <button onClick={()=>setTab('notifications')} className="flex items-center gap-1.5 px-2.5 py-1 bg-red-50 border border-red-200 text-red-600 rounded-xl text-[9px] font-black ml-auto animate-pulse">
              <Bell size={11}/>{notifications.length} alert{notifications.length>1?'s':''}
            </button>
          )}
        </header>

        <div className="flex-1 overflow-y-auto">

          {/* ══ COUNTER ══ */}
          {tab==='sales'&&(
            <CounterTab inventory={inventory} txs={txs} cart={cart} setCart={setCart} initiateSale={initiateSale} modal={modal} t={t} theme={theme}/>
          )}

          {/* ══ STOCK ══ */}
          {tab==='stock'&&(
            <div className="flex flex-col h-full">
              <div className="px-4 pt-4 pb-3 border-b border-slate-200 bg-white flex items-center gap-2 flex-wrap">
                {['inventory','suppliers','restock'].map(st=>(
                  <button key={st} onClick={()=>setStockTab(st)}
                    className={`px-4 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider transition-all ${stockTab===st?'text-white shadow-md':'bg-slate-100 text-slate-500 hover:bg-slate-200'}`}
                    style={stockTab===st?{background:theme.primary}:{}}>
                    {st==='inventory'?t('inventory'):st==='suppliers'?t('suppliers'):t('restock')}
                    {st==='restock'&&restocks.filter(r=>r.status==='pending').length>0?` (${restocks.filter(r=>r.status==='pending').length})`:''}
                  </button>
                ))}
                <div className="ml-auto">
                  {stockTab==='inventory'&&<button onClick={()=>modal('addProduct')} className="text-white px-3 py-1.5 rounded-xl text-[9px] font-black shadow-md flex items-center gap-1" style={{background:theme.primary}}><Plus size={12}/>{t('addItem')}</button>}
                  {stockTab==='suppliers'&&<button onClick={()=>{setNewSupRating(4);setNewSupItems([]);modal('addSupplier');}} className="text-white px-3 py-1.5 rounded-xl text-[9px] font-black shadow-md flex items-center gap-1" style={{background:theme.primary}}><Plus size={12}/>{t('addSupplier')}</button>}
                  {stockTab==='restock'&&<button onClick={()=>{setRestockTarget(null);modal('restock');}} className="text-white px-3 py-1.5 rounded-xl text-[9px] font-black shadow-md flex items-center gap-1" style={{background:theme.primary}}><Plus size={12}/>{t('addOrder')}</button>}
                </div>
              </div>
              <div className="flex-1 overflow-y-auto p-4 bg-slate-50">
                {stockTab==='inventory'&&<div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
                  {inventory.map(item=>(
                    <div key={item.id} className="bg-white border border-slate-200 p-4 rounded-2xl flex items-center gap-3 hover:shadow-sm transition-shadow">
                      <div className="w-10 h-10 rounded-xl flex items-center justify-center font-black text-sm shrink-0" style={{background:theme.light,color:theme.primary}}>{item.name.charAt(0)}</div>
                      <div className="flex-1 min-w-0">
                        <h3 className="font-black text-sm text-slate-800 truncate">{item.name}</h3>
                        <p className="text-[9px] text-emerald-600 font-bold">Margin: KSh {item.sellPrice-item.buyPrice}</p>
                      </div>
                      <div className="flex items-center gap-3 shrink-0">
                        <div className="text-right hidden sm:block"><p className="text-[8px] font-black uppercase" style={{color:theme.primary}}>Price</p><p className="text-sm font-black text-slate-800">KSh {item.sellPrice}</p></div>
                        <div className="text-right"><p className="text-[8px] text-slate-400 font-black uppercase">Stock</p><p className={`text-sm font-black ${item.stock<10?'text-red-600':'text-slate-800'}`}>{item.stock}</p></div>
                        <button onClick={()=>{setRestockTarget(item);setStockTab('restock');modal('restock');}} className="p-2 bg-amber-50 text-amber-600 rounded-lg hover:bg-amber-100 transition-colors"><Truck size={14}/></button>
                      </div>
                    </div>
                  ))}
                </div>}
                {stockTab==='suppliers'&&<div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  {suppliers.map(s=>(
                    <div key={s.id} className="bg-white border border-slate-200 p-5 rounded-3xl shadow-sm relative">
                      {deleteConfirmSup===s.id&&(
