// ─────────────────────────────────────────
const buildNotifications = (inventory, deni, txs, expenses) => {
  const notes = [];
  // Low stock
  inventory.filter(i=>i.stock<10).forEach(i => {
    notes.push({ id:`low_${i.id}`, type:'warning', icon:'stock', title:`Low stock: ${i.name}`, body:`Only ${i.stock} ${i.unit}(s) left. Order soon.`, date:todayStr() });
  });
  // Overdue debts
  deni.forEach(c => {
    c.debts.filter(d=>isOverdue14(d.date)).forEach(d => {
      notes.push({ id:`debt_${d.id}`, type:'danger', icon:'debt', title:`Overdue: ${c.name}`, body:`KSh ${d.amount.toLocaleString()} owed since ${fmtDate(d.date)}. Consider sending SMS.`, date:todayStr() });
    });
  });
  // Cash flow — if last 7 days deni > 30% of sales
  const recent = txs.filter(t=>new Date(t.date)>=new Date(Date.now()-7*86400000));
  const recentSales = recent.reduce((a,b)=>a+b.amount,0);
  const recentDeni  = recent.filter(t=>t.type==='DENI').reduce((a,b)=>a+b.amount,0);
  if(recentSales>0 && recentDeni/recentSales>0.3) {
    notes.push({ id:'cashflow', type:'info', icon:'cashflow', title:'High credit sales', body:`${Math.round(recentDeni/recentSales*100)}% of recent sales are on credit. Consider pushing cash/M-Pesa payments.`, date:todayStr() });
  }
  // High expenses
  const monthExp = expenses.filter(e=>e.date.startsWith(todayStr().slice(0,7))).reduce((a,b)=>a+b.amount,0);
  if(monthExp>20000) {
    notes.push({ id:'highexp', type:'info', icon:'expenses', title:'High expenses this month', body:`KSh ${monthExp.toLocaleString()} spent. Review recurring costs.`, date:todayStr() });
  }
  return notes;
};

