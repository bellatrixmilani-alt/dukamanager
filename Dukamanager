const TodayReport = ({ txs, t, theme }) => {
  const [viewDate, setViewDate] = useState(null);
  const allDates = useMemo(()=>[...new Set(txs.map(tx=>tx.date))].sort((a,b)=>b.localeCompare(a)),[txs]);
  const activeDate = viewDate || (allDates[0]||todayStr());
  const dayTxs = txs.filter(tx=>tx.date===activeDate);
  const dayTotal = dayTxs.reduce((a,b)=>a+b.amount,0);
  const dayCash  = dayTxs.filter(t=>t.type==='CASH').reduce((a,b)=>a+b.amount,0);
  const dayMpesa = dayTxs.filter(t=>t.type==='MPESA').reduce((a,b)=>a+b.amount,0);
  const dayDeni  = dayTxs.filter(t=>t.type==='DENI').reduce((a,b)=>a+b.amount,0);
  const dateIdx  = allDates.indexOf(activeDate);
  return (
    <div className="flex flex-col gap-4">
      {/* Date nav */}
      <div className="flex items-center gap-2 bg-white border border-slate-200 rounded-2xl p-2 shadow-sm">
        <button onClick={()=>{ const i=allDates.indexOf(activeDate); if(i<allDates.length-1) setViewDate(allDates[i+1]); }} disabled={dateIdx>=allDates.length-1} className="p-2 rounded-xl hover:bg-slate-100 disabled:opacity-30 transition-colors"><ArrowLeft size={15}/></button>
        <div className="flex-1 text-center">
          <p className="font-black text-sm text-slate-800">{activeDate===todayStr()?'Today':fmtDate(activeDate)}</p>
          <p className="text-[9px] text-slate-400 font-bold">{dayTxs.length} transactions</p>
        </div>
        <button onClick={()=>{ const i=allDates.indexOf(activeDate); if(i>0) setViewDate(allDates[i-1]); }} disabled={dateIdx<=0} className="p-2 rounded-xl hover:bg-slate-100 disabled:opacity-30 transition-colors"><ArrowRight size={15}/></button>
      </div>
      {/* Date pills */}
      <div className="flex gap-2 overflow-x-auto pb-1">
        {allDates.map(d=>(
          <button key={d} onClick={()=>setViewDate(d)} className={`px-3 py-1.5 rounded-xl text-[9px] font-black whitespace-nowrap border transition-all shrink-0 ${activeDate===d?'text-white border-transparent':'bg-white border-slate-200 text-slate-500'}`} style={activeDate===d?{background:theme.primary}:{}}>{d===todayStr()?'Today':fmtDate(d)}</button>
        ))}
      </div>
      {/* Stats */}
      <div className="grid grid-cols-2 lg:grid-cols-4 gap-3">
        {[{label:t('salesLogged'),val:`KSh ${dayTotal.toLocaleString()}`},{label:t('physicalCash'),val:`KSh ${dayCash.toLocaleString()}`},{label:'M-Pesa',val:`KSh ${dayMpesa.toLocaleString()}`},{label:t('newDeni'),val:`KSh ${dayDeni.toLocaleString()}`,isDeni:true}].map(s=>(
          <div key={s.label} className="bg-white border border-slate-200 p-4 rounded-2xl shadow-sm">
            <p className="text-[8px] font-black uppercase tracking-widest text-slate-400">{s.label}</p>
            <p className="text-lg font-black text-slate-800 mt-1">{s.val}</p>
            <span className={`text-[8px] font-black px-2 py-0.5 rounded-md ${s.isDeni?'bg-red-50 text-red-600':'bg-emerald-50 text-emerald-600'}`}>{s.isDeni?'↑ credit given':'↑ recorded'}</span>
          </div>
        ))}
      </div>
      {/* Transactions */}
      <div className="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm">
        <div className="p-4 border-b border-slate-100 bg-slate-50/50"><h3 className="font-black text-[9px] uppercase tracking-widest text-slate-500 flex items-center gap-2"><History size={11}/>{t('transactions')} — {activeDate===todayStr()?'Today':fmtDate(activeDate)}</h3></div>
        {dayTxs.length===0&&<div className="p-10 text-center text-slate-400"><Receipt size={24} className="mx-auto mb-2 opacity-30"/><p className="text-xs font-bold">No transactions on this date</p></div>}
        <div className="divide-y divide-slate-100">
          {dayTxs.map(tx=>(
            <div key={tx.id} className="flex justify-between items-center p-4 hover:bg-slate-50">
              <div className="flex gap-3 items-center">
                <div className={`p-2 rounded-xl ${tx.type==='CASH'?'bg-emerald-100 text-emerald-600':tx.type==='MPESA'?'bg-blue-100 text-blue-600':'bg-red-100 text-red-600'}`}>
                  {tx.type==='CASH'?<Wallet size={13}/>:tx.type==='MPESA'?<Smartphone size={13}/>:<Users size={13}/>}
                </div>
                <div><p className="text-xs font-black uppercase text-slate-800">{tx.type} Sale</p><p className="text-[8px] text-slate-500 font-bold">{tx.time} · {tx.items} item(s)</p></div>
              </div>
              <p className="font-black text-sm text-slate-800">KSh {tx.amount.toLocaleString()}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
};

