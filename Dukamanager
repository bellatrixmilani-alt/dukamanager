        <div className="flex justify-center gap-4 mb-6">{[0,1,2,3].map(i=><div key={i} className={`w-4 h-4 rounded-full border-2 transition-all ${i<entry.length?'border-0':'bg-transparent border-slate-600'}`} style={i<entry.length?{background:theme.primary}:{}}/>)}</div>
        {err&&<p className="text-red-400 text-xs font-bold mb-4 animate-pulse">{err}</p>}
        <div className="grid grid-cols-3 gap-3 mb-6">
          {['1','2','3','4','5','6','7','8','9','','0','del'].map(k=>(
